{
  "schema_version": "0.1.0",
  "type": "object",
  "required": [
    "company",
    "ticker",
    "metric_id",
    "metric_name",
    "value",
    "unit",
    "period",
    "accounting_basis",
    "statement_type",
    "source_url",
    "source_type",
    "source_date",
    "last_verified",
    "confidence"
  ],
  "properties": {
    "company": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": "string",
      "minLength": 1
    },
    "metric_id": {
      "type": "string",
      "minLength": 1
    },
    "metric_name": {
      "type": "string",
      "minLength": 1
    },
    "metric_category": {
      "type": "string",
      "enum": ["financial_metric", "share_count", "market_price"]
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string",
      "minLength": 1
    },
    "period": {
      "type": "string",
      "minLength": 1
    },
    "accounting_basis": {
      "type": "string",
      "enum": ["GAAP", "Non-GAAP", "IFRS", "Other"]
    },
    "statement_type": {
      "type": "string",
      "enum": ["fact", "assumption", "opinion"]
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": ["SEC filing", "investor relations", "earnings release", "annual report", "market data"]
    },
    "source_date": {
      "type": "string",
      "format": "date"
    },
    "last_verified": {
      "type": "string",
      "format": "date"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "notes": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "minLength": 1
    },
    "exchange": {
      "type": "string",
      "minLength": 1
    },
    "price_type": {
      "type": "string",
      "enum": ["close", "latest_trade", "opening", "intraday_snapshot"]
    },
    "as_of_datetime": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "retrieval_method": {
      "type": "string",
      "enum": ["manual_snapshot", "file_import", "market_data_agent"]
    }
  },
  "additionalProperties": false
}
